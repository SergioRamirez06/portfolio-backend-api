generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           String   @id @default(uuid())
  title        String
  description  String
  technologies String[]
  githubUrl    String   @unique
  demoUrl      String?
  image        String?
  createdAt    DateTime @default(now())
}


model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
